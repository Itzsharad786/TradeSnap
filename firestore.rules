rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Users can read and write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Groups collection
    match /groups/{groupId} {
      // Anyone authenticated can read public groups (supports legacy "Public")
      // Private groups only readable by owner or members
      allow read: if request.auth != null && (
        resource.data.type == "public" || resource.data.type == "Public" ||
        request.auth.uid == resource.data.ownerUid || 
        request.auth.uid in resource.data.get('membersUidList', [])
      );

      // Create: authenticated users only
      allow create: if request.auth != null && 
        !request.auth.token.get('isGuest', false) &&
        request.resource.data.ownerUid == request.auth.uid;

      // Update: owner or members (current/next state) can update group metadata
      // This supports join/leave flow and lastMessage/typing/presence updates.
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.ownerUid ||
        request.auth.uid in resource.data.get('membersUidList', []) ||
        request.auth.uid in request.resource.data.get('membersUidList', [])
      );

      // Delete: only owner can delete, not guests
      allow delete: if request.auth != null && 
        !request.auth.token.get('isGuest', false) &&
        request.auth.uid == resource.data.ownerUid;

      // Group members subcollection
      match /members/{memberId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/groups/$(groupId)).data.type == "public" ||
          get(/databases/$(database)/documents/groups/$(groupId)).data.type == "Public" ||
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerUid ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.get('membersUidList', [])
        );
        allow write: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerUid ||
          memberId == request.auth.uid
        );
      }

      // Group messages subcollection
      match /messages/{messageId} {
        // Read messages if user can read the parent group
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/groups/$(groupId)).data.type == "public" ||
          get(/databases/$(database)/documents/groups/$(groupId)).data.type == "Public" ||
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerUid || 
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.get('membersUidList', [])
        );

        // Create: only group members can send messages
        allow create: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.get('membersUidList', []) &&
          request.resource.data.authorId == request.auth.uid;

        // Messages cannot be updated or deleted
        allow update, delete: if false;
      }
    }

    // Per-user mapping of joined groups used by Community join flow
    match /groupMembers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
